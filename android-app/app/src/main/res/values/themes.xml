<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.MyKedai" parent="Theme.Material3.Light.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="colorPrimary">@color/brand_primary</item>
        <item name="colorSecondary">@color/brand_secondary</item>
        <item name="android:navigationBarColor">@color/surface_background</item>
        <item name="android:windowBackground">@color/surface_background</item>
    </style>

    <style name="Theme.MyKedai.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/splash_background</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_splash_foreground</item>
        <item name="windowSplashScreenIconBackgroundColor">@color/icon_background</item>
        <item name="postSplashScreenTheme">@style/Theme.MyKedai</item>
    </style>
</resources>
